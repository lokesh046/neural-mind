# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tensortonic
# Docker URL: postgresql://postgres:postgres@postgres:5432/tensortonic
# Local URL: postgresql://postgres:postgres@localhost:5432/tensortonic
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tensortonic

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Security (change this to a secure random string in production)
SECRET_KEY=supersecretjwtkeyforlocaldevelopmentonly12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Judge0 Code Execution
# Leave empty to use local Python subprocess sandbox fallback
JUDGE0_URL=
# If using Judge0, specify API keys or rapidapi keys if needed
JUDGE0_API_KEY=
